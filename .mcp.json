{
  "mcpServers": {
    "coolscan-hil-agent": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "emulator/hil/agent",
        "python",
        "-m",
        "coolscan_hil_agent.mcp_server"
      ],
      "env": {
        "LIBVIRT_URI": "qemu:///system",
        "LIBVIRT_DOMAIN": "win10-ltsc-nikonscan",
        "LIBVIRT_SNAPSHOT": "driver-bound"
      }
    }
  }
}
