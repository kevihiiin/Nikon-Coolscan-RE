# Holo3 endpoint (provisioned externally; see docs/holo3-endpoint.md)
HOLO3_BASE_URL=https://holo3.example.tailnet.ts.net/v1
HOLO3_MODEL=Hcompany/Holo3-35B-A3B
HOLO3_API_KEY=

# VNC server inside the Win10 VM (libvirt's built-in)
VNC_HOST=127.0.0.1
VNC_PORT=5900
VNC_PASSWORD=

# libvirt connection (system socket, no sudo needed once user is in libvirt group)
LIBVIRT_URI=qemu:///system
LIBVIRT_DOMAIN=win10-ltsc-nikonscan
LIBVIRT_SNAPSHOT=nikonscan-installed

# Output paths (relative to package root unless absolute)
ARTIFACTS_DIR=artifacts
RECORDINGS_DIR=recordings
BASELINES_DIR=baselines

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
